@model Employee
@{
    ViewBag.title = "Add a new Employee";
}
<h2>Edit Employee: @Model.Name</h2>

<form asp-action="Add" asp-controller="Employee">

    <div>
        <label asp-for="Name"></label>
        <input class="form form-control" asp-for="Name" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="Phone"></label>
        <input class="form form-control" asp-for="Phone" />
        <span asp-validation-for="Phone" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="Address"></label>
        <input class="form form-control" asp-for="Address" />
        <span asp-validation-for="Address" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="DepartmentId"></label>
        <input class="form form-control" asp-for="DepartmentId" />
        <span asp-validation-for="DepartmentId" class="text-danger"></span>
    </div>

    <input type="submit" class="btn btn-primary" value="Add" />
</form>


@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}