@model Employee
@{
    ViewBag.title = $"Employee {@Model.Name}";
}
<h2>Employees List</h2>

<table class="table table-hover">
    <thead>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Address</th>
            <th>Phone</th>
        </tr>
    </thead>
    <tbody>

            <tr>
                <td>@Model.Id</td>
                <td>@Model.Name</td>
                <td>@Model.Address</td>
                <td>@Model.Phone</td>
            </tr>

    </tbody>
</table>