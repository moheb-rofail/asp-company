@model Employee
@{
    ViewBag.title = $"Employee {@Model.Name}";
}
<h2>Employees List</h2>

<table class="table table-hover">
    <thead>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Address</th>
            <th>Phone</th>
            <th></th>
        </tr>
    </thead>
    <tbody>

            <tr>
                <td>@Model.Id</td>
                <td>@Model.Name</td>
                <td>@Model.Address</td>
                <td>@Model.Phone</td>
                <td>
                    <form asp-action="Remove" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('هل أنت متأكد من حذف هذا الموظف؟');">
                        
                        <button type="submit" class="btn btn-danger btn-sm">
                            حذف
                        </button>
                    </form>
                </td>
            </tr>

    </tbody>
</table>